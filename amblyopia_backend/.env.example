# Database
DATABASE_URL=postgresql+asyncpg://amblyopia_user:amblyopia_pass@localhost:5432/amblyopia_db
SYNC_DATABASE_URL=postgresql://amblyopia_user:amblyopia_pass@localhost:5432/amblyopia_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# Generate: python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# MinIO (self-hosted S3)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=amblyopia-data
MINIO_SECURE=false
MINIO_REGION=ap-south-1

# Twilio (WhatsApp + SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_SMS_NUMBER=+1234567890

# Firebase (Push Notifications)
FIREBASE_CREDENTIALS_PATH=/app/firebase-key.json

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=amblyopia_screening

# Sentry
SENTRY_DSN=your-sentry-dsn-here

# Hospital Config
HOSPITAL_NAME=Aravind Eye Hospital
HOSPITAL_DOMAIN=aravind.org
CORS_ORIGINS=https://dashboard.aravind.org,https://admin.aravind.org

# India Config
INDIA_TIMEZONE=Asia/Kolkata
INDIA_REGION=ap-south-1

# Model Config
MODEL_CONFIDENCE_THRESHOLD=0.90
MIN_CASES_FOR_RETRAINING=50
RETRAINING_SCHEDULE=0 2 * * 0

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Environment
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Airflow
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow
AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/1
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:airflow@postgres:5432/airflow
